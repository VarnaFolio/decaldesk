{
    "name": "decaldesk/decaldesk-dev-tools",
    "description": "Dev-only tooling (PHPCS, PHPStan, PHPUnit) for the DecalDesk plugin - not part of the runtime plugin, excluded from distributed builds by tools/build-free-zip.js.",
    "private": true,
    "license": "proprietary",
    "require-dev": {
        "php": ">=7.4",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "php-stubs/wordpress-stubs": "^6.9",
        "phpunit/phpunit": "^9.6 || ^10.5",
        "brain/monkey": "^2.6"
    },
    "config": {
        "vendor-dir": "tools/vendor",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse",
        "test": "phpunit"
    }
}
