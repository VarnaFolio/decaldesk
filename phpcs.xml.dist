<?xml version="1.0"?>
<ruleset name="DecalDesk">
    <description>Coding standard for the DecalDesk plugin — WordPress Coding Standards + PHP 7.4-8.3 compatibility. Dev-only tooling; not shipped with the plugin (see tools/build-free-zip.js EXCLUDE_FILES).</description>

    <file>.</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tools/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>
    <exclude-pattern>*/assets/marketplace/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="parallel" value="8"/>

    <!-- WordPress-Core (not the full "WordPress" ruleset): covers security,
         i18n, DB/API best practices, VIP-style correctness sniffs - the
         things actually worth failing a build over. Deliberately skips
         WordPress-Docs/most of WordPress-Extra's Squiz.Commenting.* strict
         docblock requirements, since this codebase intentionally keeps
         comments terse (see CLAUDE.md: comment only the non-obvious WHY). -->
    <rule ref="WordPress-Core">
        <config name="text_domain" value="decaldesk"/>
    </rule>
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="decaldesk"/>
        </properties>
    </rule>

    <!-- decaldesk.php declares "Requires PHP: 7.4"; CLAUDE.md also asks for 8.3+ readiness. -->
    <config name="testVersion" value="7.4-8.3"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- Prefix-based naming is DecalDesk's own convention (decaldesk_/DECALDESK_/DecalDesk),
         not the file-name-must-match-class/function-name rule WordPress-Extra expects. -->
    <rule ref="WordPress.Files.FileName">
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>

    <!-- Direct DB access in includes/database.php is intentional and already
         manually reviewed for $wpdb->prepare() safety: every interpolated
         fragment is either the internal decaldesk_jobs_table() helper (never
         user input) or a hardcoded literal WHERE clause, and every actual
         value placeholder goes through $wpdb->prepare(). This sniff can't
         tell "trusted internal helper" from "user input" and flags both. -->
    <rule ref="WordPress.DB.DirectDatabaseQuery">
        <exclude-pattern>*/includes/database.php</exclude-pattern>
    </rule>
    <rule ref="WordPress.DB.PreparedSQL">
        <exclude-pattern>*/includes/database.php</exclude-pattern>
    </rule>

    <!-- decaldesk.php's only direct DB calls are one-time admin operations
         (the legacy ProductOps->DecalDesk migration check/RENAME TABLE, and
         the full-uninstall DROP TABLE) - not per-request queries, so the
         "add object caching" advice this sniff gives doesn't apply. -->
    <rule ref="WordPress.DB.DirectDatabaseQuery">
        <exclude-pattern>decaldesk\.php$</exclude-pattern>
    </rule>
</ruleset>
