msgstr "Неуспешно създаване на продукта."

#: includes/settings.php:131
msgid "AI descriptions require a Pro license."
msgstr "AI описанията изискват Pro лиценз."

#: includes/settings.php:153
msgid "No Google Gemini API key set."
msgstr "Няма зададен Google Gemini API ключ."

#: includes/settings.php:159
