#. Description of the plugin
#: decaldesk.php
msgid ""
"Автоматизирано създаване на WooCommerce продукти от дизайн файлове — "
"парсване на име, ценообразуване по площ, AI описания, мокъп генериране, "
"размерни варианти."
msgstr ""
"Автоматизирано създаване на WooCommerce продукти от дизайн файлове — "
"парсване на име, ценообразуване по площ, AI описания, мокъп генериране, "
"размерни варианти."

