msgstr "Пусни файлове тук или натисни Enter за избор"

#: admin/admin-page-upload.php:18
msgid "Drop files here or click to browse"
msgstr "Пусни файлове тук или натисни за избор"

#: admin/admin-page-upload.php:20
msgid ""
"Filename format: name_widthxheight_material_category.extension (material is "
"optional: name_widthxheight_category.extension also works)"
msgstr ""
"Формат на името: name_widthxheight_material_category.разширение (материалът "
"е незадължителен: name_widthxheight_category.разширение също работи)"

#: admin/admin-page-upload.php:21
msgid ""
"Examples: holiday_50x70_matte_kitchen.jpg, or holiday_50x70_kitchen.jpg (no "
"material)"
msgstr ""
"Примери: koleda_50x70_matte_kitchen.jpg, или koleda_50x70_kitchen.jpg (без "
"материал)"

#: admin/admin-page-upload.php:22
msgid "Allowed formats: PNG, JPG/JPEG, WEBP, GIF"
msgstr "Позволени формати: PNG, JPG/JPEG, WEBP, GIF"

#. translators: %d: maximum number of files at once
