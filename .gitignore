# OS / editor artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Dependency directories (само ако по-късно добавим composer/npm build tooling
# ЗА РАЗРАБОТКА - библиотеки, ръчно vendored в плъгина, като /plugin-update-checker/,
# СЕ COMMIT-ВАТ нарочно, защото трябва да пътуват с плъгина при инсталация)
/node_modules/

# PHPCS/PHPStan dev tooling (composer.json require-dev) - инсталира се локално
# с `composer install`, не се commit-ва; отделен vendor-dir от runtime-а
# vendor/freemius/ нарочно, за да не се бъркат двете (виж composer.json).
# composer.lock СЕ commit-ва нарочно, за възпроизводими версии в CI.
/tools/vendor/

# Local build/output
*.zip
/build/
/dist/

# Environment-specific config (никога не commit-вай API ключове)
.env
.env.local

# Log files (ако някой тества локално и генерира логове в repo-то по грешка)
*.log
